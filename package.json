{
  "name": "kcart",
  "version": "0.1.0",
  "description": "kcart — multi-vendor e-commerce & food delivery app",
  "private": true,
  "scripts": {
    "dev": "npm run web:dev",
    "build": "npm run web:build",
    "start": "npm run web:serve",
    "lint": "echo 'No lint configured for static site'",
    "test": "echo 'No tests configured'",
    "web:dev": "sass --no-source-map --watch web/assets/scss/app.scss:web/assets/css/app.css",
    "web:build": "sass web/assets/scss/app.scss web/assets/css/app.css --no-source-map --style=compressed",
    "web:serve": "http-server web -p 3000 -c-1",
    "mobile:start": "cd mobile && npx expo start"
  },
  "author": "ngabonzizaguy",
  "license": "MIT",
  "dependencies": {
    
  },
  "devDependencies": {
    "sass": "^1.77.6",
    "http-server": "^14.1.1"
  }
}